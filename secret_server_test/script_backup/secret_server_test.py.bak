import requests
import json

# 1. Simulate OAuth Authentication
auth_url = "https://httpbin.org/post"  # Fixed: httpbin requires /post for POST requests
default_api_username = "your_api_username"
default_api_password = "your_api_password"

# Allow user input, falling back to hardcoded defaults
api_username = input(f"Enter api_username [{default_api_username}]: ") or default_api_username
password = input(f"Enter password [{default_api_password}]: ") or default_api_password

auth_data = {
    "api_username": api_username,
    "password": password,
    "grant_type": "password"
}

# httpbin echoes data back, so we grab 'access_token' out of the echoed form data
# or use a fallback mock token for the next step.
response_1 = requests.post(auth_url, data=auth_data).json()
token = response_1.get("form", {}).get("api_username", "MOCK_TOKEN_12345")

# 2. Simulate Creating the Secret
secret_url = "https://httpbin.org/post"  # Fixed: httpbin requires /post for POST requests
headers = {"Authorization": f"Bearer {token}", "Content-Type": "application/json"}
payload = {
    "secretTemplateId": 6000,
    "folderId": 1,
    "items": [
        {"fieldName": "Secret Name", "value": "My SFTP Secret"},
        {"fieldName": "Username", "value": "sftp_user"},
        {"fieldName": "Password", "value": "SuperSecurePassword123"},
        {"fieldName": "Notes", "value": "sftp -P 22 sftp_user@domain.com"}
    ]
}

response_2 = requests.post(secret_url, json=payload, headers=headers)

# This print will show you exactly what JSON payload was delivered to the 'server'
print(json.dumps(response_2.json(), indent=4))

